#!/usr/bin/env bpftrace
/*
 * hypothesis2_cache_migration.bt
 *
 * 验证假设2：Cache line 不抖动
 *
 * 采集指标：
 *   1. CPU 迁移次数 (sched_migrate_task)
 *   2. 任务在 CPU 间切换的模式
 *   3. 同一线程连续运行在不同 CPU 上的次数
 *
 * 注意：Cache miss 需要用 perf stat 采集，此脚本关注调度层面
 *
 * 用法：
 *   sudo bpftrace -c '<command>' hypothesis2_cache_migration.bt
 *
 * 示例：
 *   sudo bpftrace -c './db_bench --threads=64' hypothesis2_cache_migration.bt
 *   sudo bpftrace -c './lb_simple -- db_bench --threads=64' hypothesis2_cache_migration.bt
 */

BEGIN
{
    @tracked[cpid] = 1;
    printf("Tracing CPU migrations and cache effects... Hit Ctrl-C to end.\n");
    printf("PID: %d (auto-bound via -c)\n", cpid);
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

tracepoint:sched:sched_process_exit
/ @tracked[pid] /
{
    delete(@tracked[pid]);
}

/*
 * 指标1：CPU 迁移事件
 */
tracepoint:sched:sched_migrate_task
/ @tracked[args->pid] /
{
    @migrate_count++;
    @migrate_from_cpu[args->orig_cpu]++;
    @migrate_to_cpu[args->dest_cpu]++;
    @migrate_path[args->orig_cpu, args->dest_cpu]++;

    // 记录迁移距离（简化：假设 CPU 编号差异代表距离）
    $distance = args->dest_cpu > args->orig_cpu ?
                args->dest_cpu - args->orig_cpu :
                args->orig_cpu - args->dest_cpu;
    @migrate_distance = hist($distance);
}

/*
 * 指标2：每个线程的迁移次数
 */
tracepoint:sched:sched_migrate_task
/ @tracked[args->pid] /
{
    @migrate_per_thread[args->pid]++;
}

/*
 * 指标3：连续两次运行在不同 CPU 上（"软迁移"）
 * 即使没有触发 migrate_task，线程也可能在不同 CPU 上被唤醒执行
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    $tid = args->next_pid;
    $current_cpu = cpu;

    if (@last_run_cpu[$tid] >= 0 && @last_run_cpu[$tid] != $current_cpu) {
        @soft_migrate_count++;
        @soft_migrate_per_thread[$tid]++;
    }
    @last_run_cpu[$tid] = $current_cpu;
}

/*
 * 指标4：wakeup 时 target_cpu 与实际运行 CPU 的一致性
 */
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    @wakeup_target[args->pid] = args->target_cpu;
}

tracepoint:sched:sched_switch
/ @tracked[args->next_pid] && @wakeup_target[args->next_pid] >= 0 /
{
    $target = @wakeup_target[args->next_pid];
    $actual = cpu;

    if ($target == $actual) {
        @wakeup_target_hit++;
    } else {
        @wakeup_target_miss++;
        @wakeup_mismatch[$target, $actual]++;
    }
    delete(@wakeup_target[args->next_pid]);
}

/*
 * 指标5：每个 CPU 处理同一线程的次数分布
 * 高度集中说明缓存亲和性好
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    @thread_cpu_affinity[args->next_pid, cpu]++;
}

/*
 * 指标6：唤醒时使用的 CPU 选择策略观察
 * 记录 prev_cpu vs current_cpu 的关系
 */
tracepoint:sched:sched_waking
/ @tracked[args->pid] /
{
    @waking_from_cpu[cpu]++;
}

END
{
    printf("\n========================================\n");
    printf("假设2验证：Cache line 抖动 / CPU 迁移\n");
    printf("========================================\n");

    printf("\n--- 总 CPU 迁移次数 (sched_migrate_task) ---\n");
    print(@migrate_count);

    printf("\n--- 迁移源 CPU 分布 ---\n");
    print(@migrate_from_cpu);

    printf("\n--- 迁移目标 CPU 分布 ---\n");
    print(@migrate_to_cpu);

    printf("\n--- 迁移路径 (from -> to) ---\n");
    print(@migrate_path);

    printf("\n--- 迁移距离分布 (CPU 编号差) ---\n");
    print(@migrate_distance);

    printf("\n--- 每线程迁移次数 ---\n");
    print(@migrate_per_thread);

    printf("\n--- 软迁移次数 (连续运行在不同 CPU) ---\n");
    print(@soft_migrate_count);

    printf("\n--- 每线程软迁移次数 ---\n");
    print(@soft_migrate_per_thread);

    printf("\n--- 唤醒目标命中/未命中 ---\n");
    printf("Target CPU hit: ");
    print(@wakeup_target_hit);
    printf("Target CPU miss: ");
    print(@wakeup_target_miss);

    printf("\n--- 唤醒目标 vs 实际运行 CPU 不匹配情况 ---\n");
    print(@wakeup_mismatch);

    printf("\n--- 唤醒来源 CPU 分布 ---\n");
    print(@waking_from_cpu);

    printf("\n--- 线程-CPU 亲和性 (thread, cpu) -> count ---\n");
    print(@thread_cpu_affinity);

    // 清理
    clear(@tracked);
    clear(@migrate_count);
    clear(@migrate_from_cpu);
    clear(@migrate_to_cpu);
    clear(@migrate_path);
    clear(@migrate_distance);
    clear(@migrate_per_thread);
    clear(@soft_migrate_count);
    clear(@soft_migrate_per_thread);
    clear(@last_run_cpu);
    clear(@wakeup_target);
    clear(@wakeup_target_hit);
    clear(@wakeup_target_miss);
    clear(@wakeup_mismatch);
    clear(@thread_cpu_affinity);
    clear(@waking_from_cpu);
}
