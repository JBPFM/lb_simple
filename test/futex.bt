BEGIN
{
    @tracked[cpid] = 1;
    printf("Tracing futex() wait latency... Hit Ctrl-C to end.\n");
}

tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == pid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

tracepoint:sched:sched_process_exit
/ @tracked[pid] /
{
    delete(@tracked[pid]);
}

kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
  @wait_start[tid] = nsecs;
}

kretfunc:vmlinux:futex_wait
/ @tracked[pid] && @wait_start[tid] /
{
  $delta_ns = nsecs - @wait_start[tid];
  $uaddr = args->uaddr;
  @wait_ns_by_uaddr[$uaddr] = stats($delta_ns);
  delete(@wait_start[tid]);
}

kfunc:vmlinux:futex_wake
/ @tracked[pid] /
{
  @wake_start[tid] = nsecs;
}

kretfunc:vmlinux:futex_wake
/ @tracked[pid] && @wake_start[tid] /
{
  if (retval > 0) {
    $delta_ns = nsecs - @wake_start[tid];
    $uaddr = args->uaddr;
    @wake_ns_by_uaddr[$uaddr] = stats($delta_ns);
  }
  delete(@wake_start[tid]);
}

kfunc:vmlinux:futex_do_wait 
/ @tracked[pid] && @wait_start[tid]/
{
  @do_wait_start[tid] = nsecs;
}

kretfunc:vmlinux:futex_do_wait
/ @tracked[pid] && @do_wait_start[tid] /
{
  $delta_ns = nsecs - @do_wait_start[tid];
  $uaddr = (uint64 *)(args->q->key.private.address + args->q->key.private.offset);
  @do_wait_ns_by_uaddr[$uaddr] = stats($delta_ns);
  delete(@do_wait_start[tid]);
}

END
{
    printf("\n==== futex() wait latency per uaddr (ns) ====\n");
    print(@wait_ns_by_uaddr);
    printf("\n==== futex() wake latency per uaddr (ns) ====\n");
    print(@wake_ns_by_uaddr);
    printf("\n==== futex_do_wait() latency per uaddr (ns) ====\n");
    print(@do_wait_ns_by_uaddr);

    clear(@wait_start);
    clear(@wait_ns_by_uaddr);
    clear(@wake_start);
    clear(@wake_ns_by_uaddr);
    clear(@do_wait_start);
    clear(@do_wait_ns_by_uaddr);
    clear(@tracked);
}
