#!/usr/bin/env bpftrace
/*
 * hypothesis3_wakeup_latency.bt
 *
 * 验证假设3：减少了"醒了又睡"的循环
 *
 * 采集指标：
 *   1. wakeup-to-run 延迟分布
 *   2. 每个线程的 wake/wait 循环次数
 *   3. futex_wait 返回后到下次 futex_wait 的间隔（锁持有时间估算）
 *   4. 连续 futex_wait 失败（立即又 wait）的次数
 *
 * 用法：
 *   sudo bpftrace -c '<command>' hypothesis3_wakeup_latency.bt
 *
 * 示例：
 *   sudo bpftrace -c './db_bench --threads=64' hypothesis3_wakeup_latency.bt
 *   sudo bpftrace -c './lb_simple -- db_bench --threads=64' hypothesis3_wakeup_latency.bt
 */

BEGIN
{
    @tracked[cpid] = 1;
    printf("Tracing wakeup latency and wake/wait cycles... Hit Ctrl-C to end.\n");
    printf("PID: %d (auto-bound via -c)\n", cpid);
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

tracepoint:sched:sched_process_exit
/ @tracked[pid] /
{
    delete(@tracked[pid]);
}

/*
 * 指标1：wakeup-to-run 延迟
 * 从 sched_wakeup 到 sched_switch(next) 的时间
 */
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    @wakeup_ts[args->pid] = nsecs;
}

tracepoint:sched:sched_wakeup_new
/ @tracked[args->pid] /
{
    @wakeup_ts[args->pid] = nsecs;
}

tracepoint:sched:sched_switch
/ @tracked[args->next_pid] && @wakeup_ts[args->next_pid] > 0 /
{
    $latency_ns = nsecs - @wakeup_ts[args->next_pid];
    @wakeup_to_run_latency_ns = hist($latency_ns);
    @wakeup_to_run_stats = stats($latency_ns);
    @wakeup_to_run_per_thread[args->next_pid] = stats($latency_ns);
    delete(@wakeup_ts[args->next_pid]);
}

/*
 * 指标2：futex_wait 返回后到下次 futex_wait 的时间间隔
 * 短间隔 = "醒了又睡" / lock convoy
 */
kretfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @futex_return_ts[tid] = nsecs;
}

kfunc:vmlinux:futex_wait
/ @tracked[pid] && @futex_return_ts[tid] > 0 /
{
    $gap_ns = nsecs - @futex_return_ts[tid];
    @between_wait_gap_ns = hist($gap_ns);
    @between_wait_stats = stats($gap_ns);

    // 如果间隔小于 1us，认为是"立即又 wait"
    if ($gap_ns < 1000) {
        @immediate_rewait_count++;
    }
    // 如果间隔小于 10us，认为是"快速重试"
    if ($gap_ns < 10000) {
        @fast_retry_count++;
    }
    delete(@futex_return_ts[tid]);
}

/*
 * 指标3：连续 futex_wait 调用计数器（检测 lock convoy）
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @consecutive_wait[tid]++;
    @total_wait_count++;
}

// 当线程真正获得锁并做了工作后，重置计数器
// 用 sched_switch 切出作为"做了工作"的代理指标
tracepoint:sched:sched_switch
/ @tracked[args->prev_pid] && @consecutive_wait[args->prev_pid] > 0 /
{
    @consecutive_wait_hist = hist(@consecutive_wait[args->prev_pid]);
    @consecutive_wait[args->prev_pid] = 0;
}

/*
 * 指标4：futex_wake 返回值分布
 * retval = 被唤醒的线程数，0 表示没人在等
 */
kretfunc:vmlinux:futex_wake
/ @tracked[pid] /
{
    @wake_retval = hist(retval);
    if (retval == 0) {
        @wake_nobody_count++;
    }
    @total_wake_count++;
}

/*
 * 指标5：每个线程 wait 和 wake 的比率
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @wait_per_thread[tid]++;
}

kfunc:vmlinux:futex_wake
/ @tracked[pid] /
{
    @wake_per_thread[tid]++;
}

/*
 * 指标6：futex_wait 的实际睡眠时间（wait 内部延迟）
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @wait_enter_ts[tid] = nsecs;
}

kretfunc:vmlinux:futex_wait
/ @tracked[pid] && @wait_enter_ts[tid] > 0 /
{
    $duration_ns = nsecs - @wait_enter_ts[tid];
    @futex_wait_duration_ns = hist($duration_ns);
    @futex_wait_duration_stats = stats($duration_ns);
    delete(@wait_enter_ts[tid]);
}

END
{
    printf("\n========================================\n");
    printf("假设3验证：醒了又睡 / Lock Convoy\n");
    printf("========================================\n");

    printf("\n--- wakeup-to-run 延迟分布 (ns) ---\n");
    print(@wakeup_to_run_latency_ns);

    printf("\n--- wakeup-to-run 延迟统计 (ns) ---\n");
    print(@wakeup_to_run_stats);

    printf("\n--- 每线程 wakeup-to-run 延迟统计 ---\n");
    print(@wakeup_to_run_per_thread);

    printf("\n--- 两次 futex_wait 之间的间隔分布 (ns) ---\n");
    print(@between_wait_gap_ns);

    printf("\n--- 两次 futex_wait 之间的间隔统计 (ns) ---\n");
    print(@between_wait_stats);

    printf("\n--- 立即重新 wait 次数 (<1us) ---\n");
    print(@immediate_rewait_count);

    printf("\n--- 快速重试次数 (<10us) ---\n");
    print(@fast_retry_count);

    printf("\n--- 连续 wait 调用次数分布 ---\n");
    print(@consecutive_wait_hist);

    printf("\n--- futex_wake 返回值分布 (唤醒线程数) ---\n");
    print(@wake_retval);

    printf("\n--- wake 时没人在等的次数 ---\n");
    print(@wake_nobody_count);

    printf("\n--- 总 wait/wake 调用次数 ---\n");
    printf("Total wait: ");
    print(@total_wait_count);
    printf("Total wake: ");
    print(@total_wake_count);

    printf("\n--- 每线程 wait 调用次数 ---\n");
    print(@wait_per_thread);

    printf("\n--- 每线程 wake 调用次数 ---\n");
    print(@wake_per_thread);

    printf("\n--- futex_wait 内部持续时间分布 (ns) ---\n");
    print(@futex_wait_duration_ns);

    printf("\n--- futex_wait 内部持续时间统计 (ns) ---\n");
    print(@futex_wait_duration_stats);

    // 清理
    clear(@tracked);
    clear(@wakeup_ts);
    clear(@wakeup_to_run_latency_ns);
    clear(@wakeup_to_run_stats);
    clear(@wakeup_to_run_per_thread);
    clear(@futex_return_ts);
    clear(@between_wait_gap_ns);
    clear(@between_wait_stats);
    clear(@immediate_rewait_count);
    clear(@fast_retry_count);
    clear(@consecutive_wait);
    clear(@consecutive_wait_hist);
    clear(@wake_retval);
    clear(@wake_nobody_count);
    clear(@total_wait_count);
    clear(@total_wake_count);
    clear(@wait_per_thread);
    clear(@wake_per_thread);
    clear(@wait_enter_ts);
    clear(@futex_wait_duration_ns);
    clear(@futex_wait_duration_stats);
}
