#!/usr/bin/env bpftrace
/*
 * hypothesis1_concurrent_competitors.bt
 *
 * 验证假设1：减少"同时竞争者"数量
 *
 * 采集指标：
 *   1. 同一时刻 runnable 且竞争同一锁的线程数
 *   2. 每个 CPU 的 runqueue 长度分布
 *   3. 任务在各 CPU 上的分布情况
 *
 * 用法：
 *   sudo bpftrace -c '<command>' hypothesis1_concurrent_competitors.bt
 *
 * 示例：
 *   sudo bpftrace -c './db_bench --threads=64' hypothesis1_concurrent_competitors.bt
 *   sudo bpftrace -c './lb_simple -- db_bench --threads=64' hypothesis1_concurrent_competitors.bt
 */

BEGIN
{
    @tracked[cpid] = 1;
    printf("Tracing concurrent lock competitors... Hit Ctrl-C to end.\n");
    printf("PID: %d (auto-bound via -c)\n", cpid);
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

tracepoint:sched:sched_process_exit
/ @tracked[pid] /
{
    delete(@tracked[pid]);
}

/*
 * 指标1：futex wait 调用时，统计同一时刻有多少线程在等待
 * 通过记录 futex_wait 的进入和退出来估算"活跃竞争者"
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    $uaddr = args->uaddr;
    @waiting_on_lock[$uaddr]++;
    @concurrent_waiters[$uaddr] = hist(@waiting_on_lock[$uaddr]);
    @futex_wait_count++;
}

kretfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    $uaddr = args->uaddr;
    if (@waiting_on_lock[$uaddr] > 0) {
        @waiting_on_lock[$uaddr]--;
    }
}

/*
 * 指标2：runqueue 长度采样（每 10ms 采样一次）
 * 记录每个 CPU 上 runqueue 的长度分布
 */
profile:hz:100
{
    @rq_len_by_cpu[cpu] = hist(curtask->sched_info.run_delay);
    @cpu_sample_count[cpu]++;
}

/*
 * 指标3：任务被唤醒时的目标 CPU 分布
 */
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    @wakeup_target_cpu[args->target_cpu]++;
}

tracepoint:sched:sched_wakeup_new
/ @tracked[args->pid] /
{
    @wakeup_new_target_cpu[args->target_cpu]++;
}

/*
 * 指标4：任务实际运行的 CPU 分布
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    @running_on_cpu[cpu]++;
    @task_cpu_affinity[args->next_pid, cpu]++;
}

/*
 * 指标5：futex wait 调用的时间戳间隔
 * 验证 lb_simple 下 futex wait 是否更"稀疏"
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    $now = nsecs;
    if (@last_futex_wait_ts > 0) {
        $interval = $now - @last_futex_wait_ts;
        @futex_wait_interval_ns = hist($interval);
    }
    @last_futex_wait_ts = $now;
}

/*
 * 指标6：每个线程的 futex wait 次数分布
 */
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @futex_wait_per_thread[tid]++;
}

END
{
    printf("\n========================================\n");
    printf("假设1验证：同时竞争者数量\n");
    printf("========================================\n");

    printf("\n--- 总 futex_wait 调用次数 ---\n");
    print(@futex_wait_count);

    printf("\n--- 同一锁上的并发等待者数量分布 (按 uaddr) ---\n");
    print(@concurrent_waiters);

    printf("\n--- 唤醒目标 CPU 分布 ---\n");
    print(@wakeup_target_cpu);

    printf("\n--- 新任务唤醒目标 CPU 分布 ---\n");
    print(@wakeup_new_target_cpu);

    printf("\n--- 任务实际运行 CPU 分布 ---\n");
    print(@running_on_cpu);

    printf("\n--- CPU 采样次数 ---\n");
    print(@cpu_sample_count);

    printf("\n--- futex_wait 调用间隔分布 (ns) ---\n");
    print(@futex_wait_interval_ns);

    printf("\n--- 每线程 futex_wait 调用次数 ---\n");
    print(@futex_wait_per_thread);

    // 清理
    clear(@tracked);
    clear(@waiting_on_lock);
    clear(@concurrent_waiters);
    clear(@futex_wait_count);
    clear(@rq_len_by_cpu);
    clear(@cpu_sample_count);
    clear(@wakeup_target_cpu);
    clear(@wakeup_new_target_cpu);
    clear(@running_on_cpu);
    clear(@task_cpu_affinity);
    clear(@last_futex_wait_ts);
    clear(@futex_wait_interval_ns);
    clear(@futex_wait_per_thread);
}
