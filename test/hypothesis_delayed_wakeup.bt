#!/usr/bin/env bpftrace
/*
 * hypothesis_delayed_wakeup.bt - 验证"延迟唤醒减少竞争"假设
 *
 * 核心假设：
 * 1. futex_wake 唤醒线程后，select_cpu 强制调度到 prev_cpu
 * 2. prev_cpu 上可能有其他线程正在运行（spin 或持有锁）
 * 3. 被唤醒线程必须等待，给持锁线程更多执行时间
 * 4. 结果：减少无效竞争，提升整体吞吐
 *
 * 需要验证的关键指标：
 * - 唤醒时目标 CPU 是否繁忙（有其他线程运行）
 * - 唤醒到实际运行的等待时间
 * - 运行后多快能获得锁
 * - 获锁后能执行多长时间（临界区时长）
 */

BEGIN
{
    @tracked[cpid] = 1;
    @start_ts = nsecs;
    printf("=== Delayed Wakeup Hypothesis Verification ===\n");
    printf("Tracing PID: %d (auto-bound via -c)\n", cpid);
    printf("核心假设: prev_cpu 策略导致唤醒延迟，减少锁竞争\n\n");
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

/*
 * 关键点1: futex_wake 被调用 - 记录唤醒发起时间
 */
tracepoint:syscalls:sys_enter_futex
/ @tracked[pid] && (args->op & 0xf) == 1 /  // FUTEX_WAKE = 1
{
    @wake_initiated[tid] = nsecs;
    @total_wakes = @total_wakes + 1;
}

/*
 * 关键点2: 线程被唤醒 (sched_wakeup)
 * 记录：被唤醒线程、目标CPU、唤醒时间
 */
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    $target_cpu = args->target_cpu;
    $wakee_pid = args->pid;

    // 记录唤醒时间和目标CPU
    @wakeup_ts[$wakee_pid] = nsecs;
    @wakeup_target_cpu[$wakee_pid] = $target_cpu;

    // 检查目标CPU当前是否有线程正在运行
    // 通过检查该CPU上是否有我们跟踪的线程最近在运行
    @wakeup_count = @wakeup_count + 1;
}

/*
 * 关键点3: 线程开始运行 (sched_switch)
 * 测量：唤醒到运行的延迟
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] && @wakeup_ts[args->next_pid] > 0 /
{
    $pid = args->next_pid;
    $cpu = cpu;
    $now = nsecs;
    $wakeup_time = @wakeup_ts[$pid];
    $target_cpu = @wakeup_target_cpu[$pid];

    // 计算唤醒到运行的延迟
    $delay_ns = $now - $wakeup_time;
    @wakeup_to_run_delay = hist($delay_ns);

    // 检查是否在目标CPU上运行
    if ($cpu == $target_cpu) {
        @ran_on_target_cpu = @ran_on_target_cpu + 1;
    } else {
        @ran_on_different_cpu = @ran_on_different_cpu + 1;
    }

    // 分类延迟
    if ($delay_ns < 1000) {           // < 1us
        @delay_bucket_lt_1us = @delay_bucket_lt_1us + 1;
    } else if ($delay_ns < 10000) {   // 1-10us
        @delay_bucket_1_10us = @delay_bucket_1_10us + 1;
    } else if ($delay_ns < 100000) {  // 10-100us
        @delay_bucket_10_100us = @delay_bucket_10_100us + 1;
    } else if ($delay_ns < 1000000) { // 100us-1ms
        @delay_bucket_100us_1ms = @delay_bucket_100us_1ms + 1;
    } else {                          // > 1ms
        @delay_bucket_gt_1ms = @delay_bucket_gt_1ms + 1;
    }

    // 记录开始运行时间，用于计算运行时长
    @run_start[$pid] = $now;

    // 清理
    delete(@wakeup_ts[$pid]);
    delete(@wakeup_target_cpu[$pid]);
}

/*
 * 关键点4: 线程进入 futex_wait - 它在尝试获取锁
 * 测量：从运行到尝试获锁的时间
 */
tracepoint:syscalls:sys_enter_futex
/ @tracked[pid] && (args->op & 0xf) == 0 /  // FUTEX_WAIT = 0
{
    $now = nsecs;
    @futex_wait_enter[tid] = $now;
    @total_wait_attempts = @total_wait_attempts + 1;

    // 如果刚开始运行就尝试获锁
    if (@run_start[pid] > 0) {
        $run_duration = $now - @run_start[pid];
        @run_before_wait = hist($run_duration);

        // 分类：快速失败 vs 有意义的运行
        if ($run_duration < 1000) {      // < 1us - 几乎立即去抢锁
            @quick_lock_attempt = @quick_lock_attempt + 1;
        } else if ($run_duration < 10000) { // 1-10us
            @short_run_then_wait = @short_run_then_wait + 1;
        } else {
            @meaningful_run_then_wait = @meaningful_run_then_wait + 1;
        }
    }
}

/*
 * 关键点5: futex_wait 返回 - 线程获得锁或被唤醒
 */
tracepoint:syscalls:sys_exit_futex
/ @tracked[pid] && @futex_wait_enter[tid] > 0 /
{
    $now = nsecs;
    $wait_duration = $now - @futex_wait_enter[tid];
    @futex_wait_duration = hist($wait_duration);

    // 记录获锁时间，用于计算临界区时长
    @lock_acquired[tid] = $now;

    delete(@futex_wait_enter[tid]);
}

/*
 * 关键点6: 线程离开运行状态
 * 如果它持有锁，计算临界区时长
 */
tracepoint:sched:sched_switch
/ @tracked[args->prev_pid] /
{
    $pid = args->prev_pid;
    $now = nsecs;

    // 计算本次运行时长
    if (@run_start[$pid] > 0) {
        $run_duration = $now - @run_start[$pid];
        @total_run_time = hist($run_duration);
        delete(@run_start[$pid]);
    }

    // 如果持有锁，计算临界区时长
    if (@lock_acquired[tid] > 0) {
        $critical_section = $now - @lock_acquired[tid];
        @critical_section_duration = hist($critical_section);

        // 长临界区意味着线程获得了充足执行时间
        if ($critical_section > 10000) {  // > 10us
            @long_critical_sections = @long_critical_sections + 1;
        }

        delete(@lock_acquired[tid]);
    }
}

/*
 * 关键点7: 跟踪 CPU 上的并发线程数
 * 当线程被调度时，记录目标 CPU 上有多少我们的线程
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    $cpu = cpu;
    @cpu_thread_count[$cpu] = @cpu_thread_count[$cpu] + 1;
    @threads_per_cpu = hist(@cpu_thread_count[$cpu]);
}

tracepoint:sched:sched_switch
/ @tracked[args->prev_pid] /
{
    $cpu = cpu;
    if (@cpu_thread_count[$cpu] > 0) {
        @cpu_thread_count[$cpu] = @cpu_thread_count[$cpu] - 1;
    }
}

END
{
    $duration = (nsecs - @start_ts) / 1000000000;

    printf("\n");
    printf("╔══════════════════════════════════════════════════════════════╗\n");
    printf("║        Delayed Wakeup Hypothesis Verification Results        ║\n");
    printf("║          Duration: %-5d seconds                              ║\n", $duration);
    printf("╚══════════════════════════════════════════════════════════════╝\n");

    printf("\n=== 1. 唤醒统计 ===\n");
    printf("总 wake 调用: %d\n", @total_wakes);
    printf("总 wakeup 事件: %d\n", @wakeup_count);

    printf("\n=== 2. 唤醒到运行延迟分布 ===\n");
    printf("(核心指标：延迟越长说明需要等待其他线程)\n");
    print(@wakeup_to_run_delay);

    printf("\n=== 3. 延迟分类统计 ===\n");
    printf("< 1us (立即运行):     %d\n", @delay_bucket_lt_1us);
    printf("1-10us (短暂等待):    %d\n", @delay_bucket_1_10us);
    printf("10-100us (中等等待):  %d\n", @delay_bucket_10_100us);
    printf("100us-1ms (长等待):   %d\n", @delay_bucket_100us_1ms);
    printf("> 1ms (很长等待):     %d\n", @delay_bucket_gt_1ms);

    printf("\n=== 4. CPU 目标命中率 ===\n");
    printf("在目标CPU上运行:      %d\n", @ran_on_target_cpu);
    printf("在其他CPU上运行:      %d\n", @ran_on_different_cpu);

    printf("\n=== 5. 运行后行为分析 ===\n");
    printf("(验证：运行后是立即抢锁还是做了有意义的工作)\n");
    printf("总 wait 尝试:          %d\n", @total_wait_attempts);
    printf("< 1us 就去抢锁:        %d (几乎立即竞争)\n", @quick_lock_attempt);
    printf("1-10us 后抢锁:         %d (短暂运行)\n", @short_run_then_wait);
    printf("> 10us 后抢锁:         %d (有意义的运行)\n", @meaningful_run_then_wait);

    printf("\n=== 6. 运行到 wait 的时间分布 ===\n");
    print(@run_before_wait);

    printf("\n=== 7. futex_wait 持续时间分布 ===\n");
    print(@futex_wait_duration);

    printf("\n=== 8. 临界区时长分布 ===\n");
    printf("(持锁后能运行多久)\n");
    print(@critical_section_duration);
    printf("长临界区次数 (>10us): %d\n", @long_critical_sections);

    printf("\n=== 9. 总运行时长分布 ===\n");
    print(@total_run_time);

    // 清理
    clear(@tracked);
    clear(@wakeup_ts);
    clear(@wakeup_target_cpu);
    clear(@run_start);
    clear(@futex_wait_enter);
    clear(@lock_acquired);
    clear(@cpu_thread_count);
    clear(@wake_initiated);
}
