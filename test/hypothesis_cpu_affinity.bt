#!/usr/bin/env bpftrace
/*
 * hypothesis_cpu_affinity.bt - 正确测量 CPU 亲和性
 *
 * 测量:
 * 1. 硬迁移: sched_migrate_task 事件
 * 2. 软迁移: 连续两次 sched_switch 在不同 CPU
 * 3. 线程-CPU 分布: 每个线程在哪些 CPU 上运行
 * 4. 唤醒后是否在 prev_cpu 上运行
 */

BEGIN
{
    @tracked[cpid] = 1;
    @start_ts = nsecs;
    printf("=== CPU Affinity & Migration Analysis ===\n");
    printf("Tracing PID: %d (auto-bound via -c)\n", cpid);
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

/*
 * 硬迁移: 内核主动迁移任务
 */
tracepoint:sched:sched_migrate_task
/ @tracked[args->pid] /
{
    @hard_migrations = @hard_migrations + 1;
    @hard_migrate_from_to[args->orig_cpu, args->dest_cpu] =
        @hard_migrate_from_to[args->orig_cpu, args->dest_cpu] + 1;
}

/*
 * 跟踪线程上次运行的 CPU，使用特殊值标记"已初始化"
 * 用 cpu+1 存储，0 表示未初始化
 */
tracepoint:sched:sched_switch
/ @tracked[args->prev_pid] /
{
    $pid = args->prev_pid;
    $cpu = cpu;

    // 记录线程离开时的 CPU (存储 cpu+1，避免 0 歧义)
    @last_cpu[$pid] = $cpu + 1;
    @last_run_ts[$pid] = nsecs;
}

/*
 * 检测软迁移: 线程再次运行时是否在不同 CPU
 */
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    $pid = args->next_pid;
    $cpu = cpu;
    $now = nsecs;

    // 统计线程在各 CPU 上的运行次数
    @thread_cpu_runs[$pid, $cpu] = @thread_cpu_runs[$pid, $cpu] + 1;
    @total_context_switches = @total_context_switches + 1;

    // 检查是否是软迁移 (last_cpu 存的是 cpu+1)
    if (@last_cpu[$pid] > 0) {
        $prev_cpu = @last_cpu[$pid] - 1;
        if ($prev_cpu != $cpu) {
            @soft_migrations = @soft_migrations + 1;
            @soft_migrate_from_to[$prev_cpu, $cpu] =
                @soft_migrate_from_to[$prev_cpu, $cpu] + 1;

            // 计算两次运行间隔
            if (@last_run_ts[$pid] > 0) {
                $gap = $now - @last_run_ts[$pid];
                @migration_gap = hist($gap);
            }
        } else {
            @same_cpu_runs = @same_cpu_runs + 1;
        }
    }

    // 统计每个 CPU 的总运行次数
    @cpu_total_runs[$cpu] = @cpu_total_runs[$cpu] + 1;
}

/*
 * 唤醒事件: 记录 prev_cpu 和 target_cpu 的关系
 */
tracepoint:sched:sched_waking
/ @tracked[args->pid] /
{
    $pid = args->pid;
    $target_cpu = args->target_cpu;

    // 记录唤醒时选择的目标 CPU
    @wakeup_target[$pid] = $target_cpu;
    @wakeup_events = @wakeup_events + 1;

    // 检查 target_cpu 是否等于 last_cpu (prev_cpu 效果)
    // last_cpu 存的是 cpu+1
    if (@last_cpu[$pid] > 0) {
        $prev_cpu = @last_cpu[$pid] - 1;
        if ((int64)$target_cpu == (int64)$prev_cpu) {
            @wakeup_to_prev_cpu = @wakeup_to_prev_cpu + 1;
        } else {
            @wakeup_to_different_cpu = @wakeup_to_different_cpu + 1;
        }
    }
}

END
{
    $duration = (nsecs - @start_ts) / 1000000000;

    printf("\n");
    printf("╔══════════════════════════════════════════════════════════════╗\n");
    printf("║           CPU Affinity & Migration Analysis                  ║\n");
    printf("║          Duration: %-5d seconds                              ║\n", $duration);
    printf("╚══════════════════════════════════════════════════════════════╝\n");

    printf("\n=== 1. 迁移统计 ===\n");
    printf("总上下文切换:    %d\n", @total_context_switches);
    printf("硬迁移次数:      %d\n", @hard_migrations);
    printf("软迁移次数:      %d\n", @soft_migrations);
    printf("同 CPU 连续运行: %d\n", @same_cpu_runs);

    printf("\n=== 2. 唤醒目标分析 ===\n");
    printf("总唤醒事件:             %d\n", @wakeup_events);
    printf("唤醒到 prev_cpu:        %d\n", @wakeup_to_prev_cpu);
    printf("唤醒到不同 CPU:         %d\n", @wakeup_to_different_cpu);

    printf("\n=== 3. 硬迁移路径 (top 20) ===\n");
    print(@hard_migrate_from_to, 20);

    printf("\n=== 4. 软迁移路径 (top 20) ===\n");
    print(@soft_migrate_from_to, 20);

    printf("\n=== 5. 各 CPU 运行次数分布 ===\n");
    print(@cpu_total_runs);

    printf("\n=== 6. 迁移间隔分布 (ns) ===\n");
    print(@migration_gap);

    printf("\n=== 7. 线程-CPU 分布 (top 50) ===\n");
    print(@thread_cpu_runs, 50);

    // 清理
    clear(@tracked);
    clear(@last_cpu);
    clear(@last_run_ts);
    clear(@wakeup_target);
    clear(@thread_cpu_runs);
    clear(@hard_migrate_from_to);
    clear(@soft_migrate_from_to);
    clear(@cpu_total_runs);
}
