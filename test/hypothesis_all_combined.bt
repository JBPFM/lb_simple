#!/usr/bin/env bpftrace
/*
 * hypothesis_all_combined.bt
 *
 * 综合脚本：同时采集所有三个假设的关键指标
 * 用于快速对比 CFS vs lb_simple 的差异
 *
 * 假设1：减少同时竞争者
 * 假设2：Cache line 不抖动
 * 假设3：减少醒了又睡循环
 *
 * 用法：
 *   sudo bpftrace -c '<command>' hypothesis_all_combined.bt
 *
 * 示例：
 *   sudo bpftrace -c './db_bench --threads=64' hypothesis_all_combined.bt
 *   sudo bpftrace -c './lb_simple -- db_bench --threads=64' hypothesis_all_combined.bt
 */

BEGIN
{
    @tracked[cpid] = 1;
    @start_ts = nsecs;
    printf("=== Combined Hypothesis Verification ===\n");
    printf("Tracing PID: %d (auto-bound via -c)\n", cpid);
    printf("Start time: %lld\n", @start_ts);
    printf("Hit Ctrl-C to end.\n\n");
}

// 跟踪子进程
tracepoint:sched:sched_process_fork
/ (int64)args->parent_pid == cpid || @tracked[(uint64)args->parent_pid] /
{
    @tracked[args->child_pid] = 1;
}

tracepoint:sched:sched_process_exit
/ @tracked[pid] /
{
    delete(@tracked[pid]);
}

// ============================================
// 假设1：同时竞争者数量
// ============================================

// futex wait 调用计数
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    $uaddr = args->uaddr;
    @h1_waiting_on_lock[$uaddr]++;
    @h1_max_concurrent_waiters = max(@h1_waiting_on_lock[$uaddr]);
    @h1_futex_wait_total++;
}

kretfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    $uaddr = args->uaddr;
    if (@h1_waiting_on_lock[$uaddr] > 0) {
        @h1_waiting_on_lock[$uaddr]--;
    }
}

// 唤醒目标 CPU 分布
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    @h1_wakeup_cpu[args->target_cpu]++;
}

// 任务运行 CPU 分布
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    @h1_running_cpu[cpu]++;
}

// ============================================
// 假设2：CPU 迁移和缓存效应
// ============================================

// 硬迁移计数
tracepoint:sched:sched_migrate_task
/ @tracked[args->pid] /
{
    @h2_hard_migrate_count++;
    @h2_migrate_per_thread[args->pid]++;
}

// 软迁移检测
tracepoint:sched:sched_switch
/ @tracked[args->next_pid] /
{
    $tid = args->next_pid;
    $current_cpu = cpu;

    if (@h2_last_cpu[$tid] >= 0 && @h2_last_cpu[$tid] != $current_cpu) {
        @h2_soft_migrate_count++;
    }
    @h2_last_cpu[$tid] = $current_cpu;
    @h2_thread_cpu_affinity[$tid, $current_cpu]++;
}

// ============================================
// 假设3：wakeup 延迟和 wake/wait 循环
// ============================================

// wakeup-to-run 延迟
tracepoint:sched:sched_wakeup
/ @tracked[args->pid] /
{
    @h3_wakeup_ts[args->pid] = nsecs;
}

tracepoint:sched:sched_switch
/ @tracked[args->next_pid] && @h3_wakeup_ts[args->next_pid] > 0 /
{
    $latency_ns = nsecs - @h3_wakeup_ts[args->next_pid];
    @h3_wakeup_to_run_ns = hist($latency_ns);
    @h3_wakeup_latency_stats = stats($latency_ns);
    delete(@h3_wakeup_ts[args->next_pid]);
}

// 两次 futex_wait 之间的间隔（检测 lock convoy）
kretfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @h3_futex_return_ts[tid] = nsecs;
}

kfunc:vmlinux:futex_wait
/ @tracked[pid] && @h3_futex_return_ts[tid] > 0 /
{
    $gap_ns = nsecs - @h3_futex_return_ts[tid];
    @h3_between_wait_gap_ns = hist($gap_ns);

    // 快速重试计数
    if ($gap_ns < 10000) {
        @h3_fast_retry_count++;
    }
    delete(@h3_futex_return_ts[tid]);
}

// futex_wait 持续时间
kfunc:vmlinux:futex_wait
/ @tracked[pid] /
{
    @h3_wait_enter_ts[tid] = nsecs;
}

kretfunc:vmlinux:futex_wait
/ @tracked[pid] && @h3_wait_enter_ts[tid] > 0 /
{
    $duration_ns = nsecs - @h3_wait_enter_ts[tid];
    @h3_wait_duration_ns = hist($duration_ns);
    @h3_wait_duration_stats = stats($duration_ns);
    delete(@h3_wait_enter_ts[tid]);
}

// futex_wake 返回值
kretfunc:vmlinux:futex_wake
/ @tracked[pid] /
{
    @h3_wake_retval = hist(retval);
    @h3_wake_total++;
    if (retval == 0) {
        @h3_wake_nobody++;
    }
}

END
{
    $duration_s = (nsecs - @start_ts) / 1000000000;
    printf("\n");
    printf("╔══════════════════════════════════════════════════════════════╗\n");
    printf("║          Hypothesis Verification Results                     ║\n");
    printf("║          Duration: %lld seconds                               ║\n", $duration_s);
    printf("╚══════════════════════════════════════════════════════════════╝\n");

    printf("\n");
    printf("┌──────────────────────────────────────────────────────────────┐\n");
    printf("│ 假设1：减少同时竞争者                                        │\n");
    printf("└──────────────────────────────────────────────────────────────┘\n");

    printf("\n[1.1] 总 futex_wait 调用次数:\n");
    print(@h1_futex_wait_total);

    printf("\n[1.2] 同一锁上最大并发等待者:\n");
    print(@h1_max_concurrent_waiters);

    printf("\n[1.3] 唤醒目标 CPU 分布:\n");
    print(@h1_wakeup_cpu);

    printf("\n[1.4] 任务运行 CPU 分布:\n");
    print(@h1_running_cpu);

    printf("\n");
    printf("┌──────────────────────────────────────────────────────────────┐\n");
    printf("│ 假设2：Cache line 不抖动 / CPU 迁移                          │\n");
    printf("└──────────────────────────────────────────────────────────────┘\n");

    printf("\n[2.1] 硬迁移次数 (sched_migrate_task):\n");
    print(@h2_hard_migrate_count);

    printf("\n[2.2] 软迁移次数 (连续运行在不同 CPU):\n");
    print(@h2_soft_migrate_count);

    printf("\n[2.3] 每线程迁移次数:\n");
    print(@h2_migrate_per_thread);

    printf("\n[2.4] 线程-CPU 亲和性 (top 20):\n");
    print(@h2_thread_cpu_affinity);

    printf("\n");
    printf("┌──────────────────────────────────────────────────────────────┐\n");
    printf("│ 假设3：减少 wake/wait 循环                                   │\n");
    printf("└──────────────────────────────────────────────────────────────┘\n");

    printf("\n[3.1] wakeup-to-run 延迟分布 (ns):\n");
    print(@h3_wakeup_to_run_ns);

    printf("\n[3.2] wakeup-to-run 延迟统计 (ns):\n");
    print(@h3_wakeup_latency_stats);

    printf("\n[3.3] 两次 futex_wait 间隔分布 (ns):\n");
    print(@h3_between_wait_gap_ns);

    printf("\n[3.4] 快速重试次数 (<10us):\n");
    print(@h3_fast_retry_count);

    printf("\n[3.5] futex_wait 持续时间分布 (ns):\n");
    print(@h3_wait_duration_ns);

    printf("\n[3.6] futex_wait 持续时间统计 (ns):\n");
    print(@h3_wait_duration_stats);

    printf("\n[3.7] futex_wake 返回值分布:\n");
    print(@h3_wake_retval);

    printf("\n[3.8] wake 时没人等待的次数:\n");
    print(@h3_wake_nobody);

    printf("\n[3.9] 总 wake 调用次数:\n");
    print(@h3_wake_total);

    printf("\n");
    printf("╔══════════════════════════════════════════════════════════════╗\n");
    printf("║                      Summary Metrics                         ║\n");
    printf("╚══════════════════════════════════════════════════════════════╝\n");
    printf("\n");

    // 清理
    clear(@tracked);
    clear(@start_ts);

    clear(@h1_waiting_on_lock);
    clear(@h1_max_concurrent_waiters);
    clear(@h1_futex_wait_total);
    clear(@h1_wakeup_cpu);
    clear(@h1_running_cpu);

    clear(@h2_hard_migrate_count);
    clear(@h2_soft_migrate_count);
    clear(@h2_migrate_per_thread);
    clear(@h2_last_cpu);
    clear(@h2_thread_cpu_affinity);

    clear(@h3_wakeup_ts);
    clear(@h3_wakeup_to_run_ns);
    clear(@h3_wakeup_latency_stats);
    clear(@h3_futex_return_ts);
    clear(@h3_between_wait_gap_ns);
    clear(@h3_fast_retry_count);
    clear(@h3_wait_enter_ts);
    clear(@h3_wait_duration_ns);
    clear(@h3_wait_duration_stats);
    clear(@h3_wake_retval);
    clear(@h3_wake_total);
    clear(@h3_wake_nobody);
}
